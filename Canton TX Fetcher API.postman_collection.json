  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Auth0 Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set('accessToken', jsonData.access_token);",
                  "    console.log('Access token saved successfully');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"http://auth0.com/oauth/grant-type/password-realm\",\n  \"realm\": \"{{dbRealm}}\",\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"client_id\": \"{{clientId}}\",\n  \"client_secret\": \"{{clientSecret}}\",\n  \"audience\": \"{{audienceTemplate}}\",\n  \"scope\": \"openid profile email\"\n}"
            },
            "url": {
              "raw": "{{auth0Domain}}",
              "host": [
                "{{auth0Domain}}"
              ]
            },
            "description": "Fetches an Auth0 access token for authenticating with Canton API endpoints. The token is automatically saved to the collection variable 'accessToken'."
          },
          "response": []
        }
      ],
      "description": "Authentication endpoints for obtaining access tokens"
    },
    {
      "name": "Wallet Operations",
      "item": [
        {
          "name": "Get Transactions",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page_size\": 1000,\n  \"begin_after_id\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/validator/v0/wallet/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "validator",
                "v0",
                "wallet",
                "transactions"
              ]
            },
            "description": "Fetches a paginated list of wallet transactions. Use 'begin_after_id' with an event_id from the last transaction to paginate through results."
          },
          "response": []
        },
        {
          "name": "Get Transactions (with pagination)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"page_size\": 100,\n  \"begin_after_id\": \"<event_id_from_last_transaction>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/validator/v0/wallet/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "validator",
                "v0",
                "wallet",
                "transactions"
              ]
            },
            "description": "Fetches a paginated list of wallet transactions starting after a specific event_id. Replace '<event_id_from_last_transaction>' with an actual event_id."
          },
          "response": []
        },
        {
          "name": "Get Balance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/validator/v0/wallet/balance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "validator",
                "v0",
                "wallet",
                "balance"
              ]
            },
            "description": "Fetches the current wallet balance for the validator."
          },
          "response": []
        },
        {
          "name": "Get User Status",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/validator/v0/wallet/user-status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "validator",
                "v0",
                "wallet",
                "user-status"
              ]
            },
            "description": "Fetches the current user status including party_id for the validator."
          },
          "response": []
        }
      ],
      "description": "Core wallet operations including transactions, balance, and user status"
    },
