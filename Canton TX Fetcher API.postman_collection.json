{
  "info": {
    "_postman_id": "ac559504-df05-479a-9fdb-3898bc18baaa",
    "name": "Canton TX Fetcher API",
    "description": "API collection for Canton Network validator wallet operations based on CantonTxFetcher",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "24307033",
